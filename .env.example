# Copy this file to .env and fill in a real key to enable the AI Tutor chat.
ANTHROPIC_API_KEY=sk-ant-...

# Firebase (client SDK) - see FIREBASE_SETUP.md for how to get these values.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Admin (backend-only, no VITE_ prefix - never reaches the browser).
# Required for /api/chat and /api/compile - both require sign-in and verify
# the request's Firebase ID token against this. Base64-encoded service
# account JSON - see FIREBASE_SETUP.md step 7 for how to generate it.
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Where web-ui should send /api/* requests. Leave blank for local dev (Vite's
# proxy in web-ui/vite.config.js handles it) - set to the hosted backend's
# URL (e.g. https://your-backend.fly.dev) in production. See DEPLOYMENT.md.
VITE_API_BASE_URL=

# Comma-separated origin(s) the backend accepts CORS requests from, e.g.
# https://your-app.vercel.app. Leave blank for local dev (allows everything -
# fine, since browsers don't enforce CORS between localhost ports the way
# they'd matter in production). See DEPLOYMENT.md.
CORS_ORIGIN=
